# MQTT Broker Configuration
MQTT_BROKER=your_mqtt_broker_ip
MQTT_PORT=1883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password
MQTT_TOPIC=home/fancontroller/occupancy/state
MQTT_CLIENT_ID=YOLO_Occupancy_Detector

# Detection Settings
MODEL_NAME=yolov8n.pt
CONFIDENCE_THRESHOLD=0.6
TARGET_CLASS_ID=0
DEVICE=cuda

# Detection Zone Configuration (Comma-separated: x_min,y_min,x_max,y_max)
DETECTION_ZONE=0.1,0.1,0.9,0.9

# Timing Rules (in seconds)
DETECTION_ON_DELAY=5.0
DETECTION_OFF_DELAY=120.0

# Camera Settings
CAMERA_INDEX=0
CAMERA_RECONNECT_INTERVAL=5.0
FPS_LIMIT=20

# UI Settings
WINDOW_WIDTH=960
WINDOW_HEIGHT=720
WINDOW_NAME=Smart Fan Human Detection Automation

# Paths & Features
SAVE_SCREENSHOTS=False
CAPTURE_DIR=captures
